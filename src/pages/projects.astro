---
import ArchiveLayout from '../layouts/ArchiveLayout.astro';
import { site } from '@data/site';
import { Icon } from 'astro-icon/components';

const title = `${site.projectArchivePage.title} | ${site.hero.name}`;
const description = site.projectArchivePage.description;
const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const homeHref = base;
---

<ArchiveLayout title={title} description={description}>
  <p class="mb-8">
    <a
      href={homeHref}
      class="group flex items-center gap-2 text-sm text-accent transition hover:text-slate-light"
      data-astro-prefetch
    >
      <Icon name="ph:arrow-left" class="h-4 w-4 transition-transform group-hover:-translate-x-1" />
      {site.hero.name}
    </a>
  </p>

  <h1 class="mb-8 text-4xl font-bold tracking-tight text-white sm:text-4xl">{site.projectArchivePage.title}</h1>

  <p class="mb-10 max-w-prose body-copy">
    {site.projectArchivePage.intro}
  </p>

  <div class="overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full table-fixed border-spacing-0 text-left text-sm">
        <thead class="text-slate">
          <tr>
            <th scope="col" class="whitespace-nowrap px-4 py-4 text-xs font-medium uppercase tracking-[0.25em]">
              Year
            </th>
            <th scope="col" class="px-4 py-4 text-xs font-medium uppercase tracking-[0.25em]">
              Project
            </th>
            <th scope="col" class="px-4 py-4 text-xs font-medium uppercase tracking-[0.25em]">
              Role
            </th>
            <th scope="col" class="px-4 py-4 text-xs font-medium uppercase tracking-[0.25em]">
              Tech stack
            </th>
          </tr>
        </thead>
        <tbody>
          {
            site.projectArchive.map((row) => (
              <tr>
                <td class="whitespace-nowrap px-4 py-4 font-mono text-slate">{row.date}</td>
                <td class="px-4 py-4 text-slate">{row.project}</td>
                <td class="px-4 py-4 text-slate">{row.role}</td>
                <td class="px-4 py-4 text-accent">{row.techStack}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </div>
</ArchiveLayout>

---
import type { FeaturedProject } from '../../data/site';
import ProjectCard from './ProjectCard.astro';
import { Icon } from 'astro-icon/components';

interface Props {
  projects: readonly FeaturedProject[];
}

const { projects } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const archiveHref = `${base}projects`;
---

<section
  id="featured-projects"
  class="mb-20 scroll-mt-24 lg:mb-28 lg:scroll-mt-8"
  aria-labelledby="projects-heading"
>
  <h2 id="projects-heading" class="section-heading">Featured Projects</h2>
  <div class="space-y-20">
    {projects.map((project) => (
      <ProjectCard project={project} imageSrc={project.image ? `${base}${project.image}` : undefined} />
    ))}
  </div>
  <p class="mt-14">
    <a
      href={archiveHref}
      class="group flex items-center gap-2 text-sm text-accent transition hover:text-slate-light"
      data-astro-prefetch
    >
      View Full Project Archive
      <Icon name="ph:arrow-right" class="ml-2 h-4 w-4 transition-transform group-hover:translate-x-1" />
    </a>
  </p>
</section>

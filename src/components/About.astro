---
import { site } from '@data/site';

type AboutParagraph =
  | string
  | {
      text?: string;
      link?: { text: string; href: string };
      textAfter?: string;
      heading?: string;
      bullets?: string[];
      techItems?: string[];
    };

const paragraphs = site.about.paragraphs as readonly AboutParagraph[];
---

<section
  id="about"
  class="mb-24 scroll-mt-24 lg:mb-32 lg:scroll-mt-8"
  aria-labelledby="about-heading"
>
  <h2 id="about-heading" class="section-heading">About</h2>
  <div class="reveal-content mt-8 grid items-start gap-10">
    <div class="space-y-8 body-copy">
      {paragraphs.map((p) =>
        typeof p === 'string' ? (
          <p>{p}</p>
        ) : (
          <>
            {'text' in p && p.text !== undefined && (
              <p>
                {p.text}
                {p.link && (
                  <a href={p.link.href} class="subtle-link text-accent" target="_blank" rel="noreferrer">
                    {p.link.text}
                  </a>
                )}
                {'textAfter' in p && p.textAfter}
              </p>
            )}
            {p.heading && (
              <div class="space-y-2">
                <p class="font-semibold text-white-soft">{p.heading}</p>

                {p.bullets && (
                  <ul class="list-disc space-y-1 pl-5">
                    {p.bullets.map((bullet) => (
                      <li>{bullet}</li>
                    ))}
                  </ul>
                )}

                {p.techItems && (
                  <div class="mt-3 flex flex-wrap gap-2">
                    {p.techItems.map((tech) => (
                      <span class="rounded-full border border-accent/30 bg-accent/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-accent">
                        {tech}
                      </span>
                    ))}
                  </div>
                )}
              </div>
            )}
          </>
        )
      )}
    </div>
  </div>
</section>

<style is:global>
  .reveal-content {
    opacity: 0;
    transform: translateY(20px);
    animation: revealIn 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
  }

  @keyframes revealIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
---
import { site } from '../../data/site';
---

<section id="experiences" class="mb-24 scroll-mt-24 lg:mb-32 lg:scroll-mt-8" aria-labelledby="experience-heading">
  <h2 id="experience-heading" class="section-heading">Experiences</h2>
  <div class="space-y-4">
    {
      site.experiences.map((item) => (
        <article class="scroll-stat panel-card group grid gap-4 md:grid-cols-[9rem_1fr] md:gap-6">
          <p class="pt-1 font-mono text-xs uppercase tracking-wider text-slate">{item.period}</p>
          <div class="space-y-3">
            <h3 class="text-base font-semibold text-slate uppercase">
              {item.title} · {item.company}
            </h3>
            <p class="body-copy">{item.summary}</p>
            <ul class="list-disc space-y-1 pl-5 text-sm text-slate">
              {item.highlights.map((point) => <li>{point}</li>)}
            </ul>
            <ul class="flex flex-wrap gap-3 pt-1">
              {item.tech.map((tech) => <li class="font-mono text-xs text-accent">{tech}</li>)}
            </ul>
          </div>
        </article>
      ))
    }
  </div>
</section>

<style>
  .scroll-stat {
    opacity: 0;
    transform: translateY(20px) scale(0.95);
    transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .scroll-stat.reveal {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
</style>

<script>
  function revealCards() {
    const cards = document.querySelectorAll('.scroll-stat');
    
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const index = Array.from(cards).indexOf(entry.target);
          setTimeout(() => {
            entry.target.classList.add('reveal');
          }, (index % 3) * 150); 
          
          observer.unobserve(entry.target);
        }
      });
    }, {
      threshold: 0.15,
      rootMargin: '0px 0px -10px 0px'
    });

    cards.forEach(card => observer.observe(card));
  }

  revealCards();
  
  document.addEventListener('astro:after-swap', revealCards);
</script>

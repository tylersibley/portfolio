---
import { site } from '@data/site';
import ContactBar from './ContactBar.astro';

interface Props {
  variant: 'sidebar' | 'mobile';
}

const { variant } = Astro.props;
const isSidebar = variant === 'sidebar';
---

{isSidebar ? (
  <>
    <div class="relative group mb-8 reveal-content flex justify-center" style="animation-delay: 100ms;">
      <div class="balloon-float w-20 h-20 md:w-24 md:h-24 rounded-full border-2 border-accent overflow-hidden shadow-[0_0_50px_color-mix(in_srgb,var(--color-accent)_33%,transparent)]">
        <img
          src={site.hero.avatarSrc}
          alt={site.hero.avatarAlt}
          class="h-full w-full scale-110 object-cover"
          loading="eager"
          decoding="async"
          width="96"
          height="96"
        />
      </div>
      <div class="balloon-float absolute -z-10 top-0 left-0 h-full w-full rounded-full"></div>
    </div>

    <div class="flex flex-col items-center text-center">
      <a href={import.meta.env.BASE_URL} class="text-5xl font-bold tracking-tight text-white transition">
        {site.hero.name}
      </a>
      <p class="mt-3 text-xl font-medium text-slate-light">{site.hero.role}</p>
      <p class="body-copy mt-5 max-w-xs">{site.hero.tagline}</p>
      <p class="body-copy mt-5 max-w-xs">{site.hero.contact}</p>

      <div class="mt-3 flex justify-center gap-4">
        <ContactBar />
      </div>
    </div>
  </>
) : (
  <div class="flex flex-col items-center text-center">
    <div class="relative mb-4">
      <div class="h-20 w-20 rounded-full border-2 border-accent overflow-hidden shadow-[0_0_40px_color-mix(in_srgb,var(--color-accent)_28%,transparent)]">
        <img
          src={site.hero.avatarSrc}
          alt={site.hero.avatarAlt}
          class="h-full w-full object-cover"
          loading="eager"
          decoding="async"
          width="80"
          height="80"
        />
      </div>
    </div>
    <h1 class="text-4xl font-bold tracking-tight text-white transition">
      {site.hero.name}
    </h1>
    <p class="mt-3 text-xl font-semibold tracking-tight text-slate-light">{site.hero.role}</p>
    <div class="mt-4 max-w-prose space-y-3 text-lg leading-relaxed text-slate">
      <p>{site.hero.tagline}</p>
      <p>{site.hero.contact}</p>
    </div>
    <div class="mt-2 mb-6 flex items-center justify-center gap-4">
      <ContactBar />
    </div>
  </div>
)}

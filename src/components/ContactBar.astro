---
import { site } from '@data/site';
import { Icon } from 'astro-icon/components';
---

<div class="flex items-center gap-1">
  <a
    href={site.contact.github}
    class="subtle-link inline-flex h-9 w-9 items-center justify-center rounded"
    target="_blank"
    rel="noreferrer"
    aria-label="GitHub"
  >
    <Icon name="ph:github-logo" class="h-6 w-6" />
  </a>
  <a
    href={site.contact.linkedin}
    class="subtle-link inline-flex h-9 w-9 items-center justify-center rounded"
    target="_blank"
    rel="noreferrer"
    aria-label="LinkedIn"
  >
    <Icon name="ph:linkedin-logo" class="h-6 w-6" />
  </a>
  <a
    href={`mailto:${site.contact.email}`}
    class="subtle-link inline-flex h-9 w-9 items-center justify-center rounded"
    aria-label="Email"
  >
    <Icon name="ph:envelope-simple" class="h-6 w-6" />
  </a>
</div>
